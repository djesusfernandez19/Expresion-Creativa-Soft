rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: customers
    // Fields: name (string), email (string), phone (string), address (string)
    //
    // Collection: machines
    // Fields: name (string), type (string), costPerHour (number), setupCost (number), maxFormat (string)
    //
    // Collection: materials
    // Fields: name (string), type (string), costPerUnit (number), stock (number)
    //
    // Collection: quotes
    // Fields: customerId (string), machineId (string), materialId (string), quantity (number), totalCost (number), status (string), createdAt (timestamp)
    //
    // Collection: orders
    // Fields: quoteId (string), status (string), deadline (timestamp), assignedTo (string)
    //
    // Collection: kpis
    // Fields: date (string), totalOrders (number), totalRevenue (number), efficiency (number)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "djesusfernandez19@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /machines/{machineId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /materials/{materialId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /kpis/{kpiId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
  }
}
